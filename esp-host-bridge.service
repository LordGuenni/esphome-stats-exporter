[Unit]
Description=ESP Host Bridge - Display metrics agent
After=network.target

[Service]
Type=simple
ExecStart=/opt/esp-host-bridge/esp-host-bridge --enable-vms --virsh-uri qemu:///system
Restart=always
RestartSec=5
User=root

# Environment
Environment=RUST_LOG=info

# Security hardening
NoNewPrivileges=false
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=true

# Access to devices (auto-detect ESPHome USB)
DevicePolicy=auto

[Install]
WantedBy=multi-user.target
